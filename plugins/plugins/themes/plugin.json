{
	"name": "Themes",
	"description": "Adds more themes for you to choose from",
	"version": "v6",
	"hooks": {
		"add_themes": {
			"constant": [
				{
					"id": "sleek",
					"name": "Sleek",
					"description": "A sleek, modern dark theme",
					"type": "base",
					"css": "$file:sleek.css",
					"color": "var(--bg4)"
				},
				{
					"id": "ghost",
					"name": "Ghost",
					"description": "White accent colors",
					"type": "overlay",
					"css": "$file:ghost.css",
					"color": "#ffffff"
				}
			]
		}
	}
}