{
	"id": "weld",
	"name": "Weld",
	"description": "Weld data and resource packs together for better compatability",
	"documentation": "https://nitrolaunch.github.io/nitrolaunch/plugins/plugins/weld",
	"version": "v6",
	"protocol_version": 3,
	"raw_transfer": true,
	"hooks": {
		"on_instance_setup": {
			"executable": "./weld.pyz",
			"priority": "last"
		},
		"after_packages_installed": {
			"executable": "./weld.pyz",
			"priority": "last"
		},
		"update_world_files": {
			"executable": "./weld.pyz",
			"priority": "last"
		},
		"add_instance_config_controls": {
			"constant": {
				"controls": [
					{
						"id": "disable_weld",
						"name": "Disable",
						"description": "Whether to disable pack welding on this instance",
						"section": "Weld",
						"schema": {
							"type": "boolean"
						}
					},
					{
						"id": "weld_ignore",
						"name": "Ignore",
						"description": "Filenames of packs to ignore when welding",
						"section": "Weld",
						"schema": {
							"type": "string_list"
						}
					}
				]
			}
		}
	}
}